# =============================================================================
# Terraform Variables — Example Configuration
# =============================================================================
# Copy this file to terraform.tfvars and fill in your own values.
# terraform.tfvars is in .gitignore and must never be committed.
#
# Usage:
#   cp terraform.tfvars.example terraform.tfvars
# =============================================================================


# AWS region to deploy all resources into.
aws_region = "us-east-1"

# Base name used for all AWS resources (S3 buckets, Lambda functions, IAM roles, etc.).
# Must be globally unique for S3 bucket naming — use a name specific to your project.
project_name = "your-project-name"

# WAF Web ACL ARN attached to your CloudFront distribution.
# Find this in AWS Console → WAF & Shield → Web ACLs (set region to Global/CloudFront).
# If your distribution was created with a WAF subscription plan, this is required —
# AWS will reject any attempt to remove the WAF from that distribution.
cloudfront_waf_arn = "arn:aws:wafv2:us-east-1:YOUR_ACCOUNT_ID:global/webacl/YOUR_WEBACL_NAME/YOUR_WEBACL_ID"

# Lambda layer ARNs for the imageValidator function (Pillow, OpenCV, filetype).
# These layers must be compatible with the Lambda runtime (python3.12).
#
# Option A — Use the public KLayers for Pillow (recommended, no setup needed):
#   Pillow: https://github.com/keithrozario/Klayers (find the ARN for your region + runtime)
#
# Option B — Build your own layers and publish them to your account:
#   See README.md → Deployment → Lambda Layers for build instructions.
#
# A single consolidated arm64 layer containing Pillow, opencv-python-headless, and filetype.
# Build with: pip install --platform manylinux2014_aarch64 --python-version 3.12
#             --implementation cp --only-binary=:all: -t python/ pillow opencv-python-headless filetype
# Publish with --compatible-architectures arm64
validator_layer_arns = [
  "arn:aws:lambda:REGION:ACCOUNT_ID:layer:YOUR_ARM64_LAYER:VERSION",
]
